# Server
PORT=8080

# NeoHub (WhatsApp Broker)
NEOHUB_BASE_URL=https://broker-api.neobpo.com.br
NEOHUB_API_KEY=your_neohub_api_key_here
NEOHUB_WABA_ID=your_waba_id_here

# WatsonX Assistant (IBM Watson Assistant v2)
WATSONX_BASE_URL=https://api.us-south.assistant.watson.cloud.ibm.com
WATSONX_API_KEY=your_watson_api_key_here
WATSONX_ENVIRONMENT_ID=your_environment_id_here
WATSONX_ASSISTANT_ID=your_assistant_id_here
WATSONX_VERSION=2021-11-27

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=your_redis_password_here
